datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─── USERS & AUTH ────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  clerkId       String?  @unique
  email         String   @unique
  name          String?
  password      String?
  emailVerified Boolean  @default(false)
  role          Role     @default(STUDENT)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creatorProfile       CreatorProfile?
  emailVerifications   EmailVerification[]
  sessions             Session[]
  coursesCreated       CreatorCourse[]        @relation("CreatorToCourse")
  drafts               CourseDraft[]          @relation("CreatorDrafts")
  purchases            Purchase[]
  enrollments          Enrollment[]           @relation("StudentEnrollments")
  cohortEnrollments    CohortEnrollment[]
  assignmentsSubmitted AssignmentSubmission[]
}

enum Role {
  STUDENT
  ADMIN
  TUTOR
  CREATOR
}

model CreatorProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  bio       String?
  specialty String?
  website   String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  otp       String
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

// ─── BLOG ────────────────────────────────────────────────────────────────────

model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String?  @unique
  content    String
  excerpt    String?
  image      String?
  tag        String?
  author     String?
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── COURSE CREATION PIPELINE ────────────────────────────────────────────────

/// Staging area — creator edits before submitting for review
model CourseDraft {
  id          String      @id @default(cuid())
  title       String?
  description String?
  price       Float?
  thumbnail   String?
  zipFileUrl  String?
  creatorId   String
  creator     User        @relation("CreatorDrafts", fields: [creatorId], references: [id])
  videos      DraftVideo[]
  status      DraftStatus @default(EDITING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum DraftStatus {
  EDITING
  SUBMITTED
}

/// Individual video staged inside a draft
model DraftVideo {
  id          String      @id @default(cuid())
  draftId     String
  title       String
  description String?
  order       Int
  fileName    String      // original filename from ZIP
  fileUrl     String?     // Supabase storage URL after upload
  isFree      Boolean     @default(false)
  draft       CourseDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
}

/// Published course (PENDING → APPROVED → live on catalog)
model CreatorCourse {
  id          String       @id @default(cuid())
  title       String
  description String
  price       Float
  status      CourseStatus @default(PENDING)
  thumbnail   String?
  draftId     String?
  creatorId   String
  creator     User         @relation("CreatorToCourse", fields: [creatorId], references: [id])
  videos      CourseVideo[]
  purchases   Purchase[]
  enrollments Enrollment[] @relation("CourseEnrollments")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum CourseStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Ordered video in a published course
model CourseVideo {
  id          String        @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  fileUrl     String
  isFree      Boolean       @default(false)
  course      CreatorCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    VideoProgress[]
  createdAt   DateTime      @default(now())
}

// ─── PURCHASES & ENROLLMENT INSTANCES ────────────────────────────────────────

model Purchase {
  id        String        @id @default(cuid())
  userId    String
  courseId  String
  amount    Float
  reference String?       @unique
  user      User          @relation(fields: [userId], references: [id])
  course    CreatorCourse @relation(fields: [courseId], references: [id])
  createdAt DateTime      @default(now())
}

/// One enrollment = one student's private classroom instance for a course
model Enrollment {
  id          String          @id @default(cuid())
  userId      String
  courseId    String
  user        User            @relation("StudentEnrollments", fields: [userId], references: [id])
  course      CreatorCourse   @relation("CourseEnrollments", fields: [courseId], references: [id])
  completedAt DateTime?
  progress    VideoProgress[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, courseId])
}

/// Per-video watch progress within an enrollment
model VideoProgress {
  id            String      @id @default(cuid())
  enrollmentId  String
  videoId       String
  progressSec   Int         @default(0)
  completed     Boolean     @default(false)
  lastWatchedAt DateTime?
  enrollment    Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  video         CourseVideo @relation(fields: [videoId], references: [id])

  @@unique([enrollmentId, videoId])
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  type      String
  title     String
  message   String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

// ─── ACADEMY COHORT COURSES ───────────────────────────────────────────────────

model AcademyCourse {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  description      String
  thumbnail        String?
  level            String   @default("Beginner")
  duration         String   @default("8 Weeks")
  price            String   @default("NGN5,000")
  isProgramming    Boolean  @default(false)
  instructorName   String?
  instructorAvatar String?
  instructorRole   String?
  color            String   @default("from-blue-600 to-indigo-600")
  buttonColor      String   @default("bg-white text-blue-600")
  modules          Json?
  cohorts          Cohort[]
}

model Cohort {
  id                 String             @id @default(cuid())
  name               String
  courseId           String
  course             AcademyCourse      @relation(fields: [courseId], references: [id])
  tutorId            String?
  tutorName          String?
  startDate          DateTime?
  endDate            DateTime?
  maxStudents        Int                @default(20)
  price              Float              @default(50000)   // in NGN kobo-safe float
  partPaymentEnabled Boolean            @default(true)
  partPaymentPercent Int                @default(50)      // e.g. 50 = pay 50% now
  enrollments        CohortEnrollment[]
  assignments        Assignment[]
  createdAt          DateTime           @default(now())
}

model CohortEnrollment {
  id            String               @id @default(cuid())
  userId        String
  cohortId      String
  user          User                 @relation(fields: [userId], references: [id])
  cohort        Cohort               @relation(fields: [cohortId], references: [id])
  totalAmount   Float                @default(0)
  amountPaid    Float                @default(0)
  paymentStatus AcademyPaymentStatus @default(UNPAID)
  reference     String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([userId, cohortId])
}

enum AcademyPaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model Assignment {
  id          String               @id @default(cuid())
  title       String
  description String
  cohortId    String
  cohort      Cohort               @relation(fields: [cohortId], references: [id])
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  userId       String
  fileUrl      String?
  grade        String?
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
}
